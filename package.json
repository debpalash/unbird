{
  "name": "unbird",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "A privacy-respecting, high-performance X/Twitter frontend",
  "repository": {
    "type": "git",
    "url": "https://github.com/user4/unbird.git"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun run dev:api & bun run dev:client",
    "dev:api": "bun --hot src/index.ts",
    "dev:client": "bunx vite",
    "build": "bunx vite build",
    "start": "NODE_ENV=production bun src/index.ts",
    "x:login": "bun run src/server/sessions/login.ts",
    "x:login:browser": "bun run session/x-login.ts"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "geoip-lite": "^2.0.1",
    "hono": "^4.12.9",
    "jszip": "^3.10.1",
    "otplib": "^13.4.0",
    "proxy-agent": "^7.0.0",
    "wreq-js": "^2.2.2"
  },
  "devDependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "@types/bun": "latest",
    "@types/d3": "^7.4.3",
    "@types/geoip-lite": "^1.4.4",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "fast-average-color": "^9.5.1",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.545.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-virtuoso": "^4.18.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "video.js": "^8.23.7",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
