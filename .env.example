# ─── Server ───────────────────────────────────────────────────
UNBIRD_PORT=3069
UNBIRD_ADDRESS=0.0.0.0
UNBIRD_HOSTNAME=localhost:3069
UNBIRD_HTTPS=false
UNBIRD_MAX_CONNS=100
UNBIRD_TITLE=unbird
UNBIRD_STATIC_DIR=public
UNBIRD_HMAC_KEY=change-me-in-production
UNBIRD_BASE64_MEDIA=false
UNBIRD_DEBUG=false

# ─── Proxy (optional — used for Twitter API requests) ────────
UNBIRD_PROXY=
UNBIRD_PROXY_AUTH=


# ─── X/Twitter Credentials (alternative to session/acc.txt) ──
# You can provide credentials via env instead of the acc.txt file.
# The server will auto-login on startup using these.
X_USERNAME=
X_PASSWORD=
X_TOTP_SECRET=

# ─── Session Files (paths are relative to project root) ──────
SESSION_FILE_PATH=session/sessions.jsonl
ACC_FILE_PATH=session/acc.txt
